# -----------------------------------------------------
# VARIÁVEIS DE AMBIENTE DO BACKEND (EXPRESS + PRISMA)
# -----------------------------------------------------

# A Porta em que o servidor Express vai rodar
PORT=3000

# Chave Super Secreta para gerar e validar o Token de Login (JWT)
# Use chaves gigantescas na produção! (ex: geradas com openssl)
JWT_SECRET="minha_super_secreta_jwt_key"

# String de Conexão Oficial do PostgreSQL rodando no Docker
# Substitua admin e adminpassword pelas reais quando for deployar.
DATABASE_URL="postgresql://admin:adminpassword@localhost:5432/agendador_db?schema=public"
